{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://health-agent.local/schemas/issue-record.schema.json",
  "title": "IssueRecord",
  "type": "object",
  "required": [
    "profile_slug",
    "title",
    "status",
    "working_conclusion",
    "confidence_frame",
    "supporting_evidence",
    "contradicting_evidence",
    "next_best_action",
    "why_this_action_now",
    "specialist_type",
    "tests_or_discussions_to_request",
    "result_that_would_change_plan",
    "last_reviewed_at",
    "linked_sources"
  ],
  "properties": {
    "profile_slug": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["active", "monitoring", "resolved", "parked"]
    },
    "working_conclusion": {
      "type": "string",
      "minLength": 1
    },
    "confidence_frame": {
      "enum": ["clear conclusion", "likely diagnosis", "differential", "open question"]
    },
    "supporting_evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "contradicting_evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_best_action": {
      "type": "string",
      "minLength": 1
    },
    "why_this_action_now": {
      "type": "string",
      "minLength": 1
    },
    "specialist_type": {
      "type": "string",
      "minLength": 1
    },
    "tests_or_discussions_to_request": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "result_that_would_change_plan": {
      "type": "string",
      "minLength": 1
    },
    "last_reviewed_at": {
      "type": "string",
      "minLength": 1
    },
    "linked_sources": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "priority_context": {
      "type": "object",
      "properties": {
        "materially_narrows_differential": { "type": "boolean" },
        "changes_treatment_or_specialist_path": { "type": "boolean" },
        "resolves_missing_objective_evidence": { "type": "boolean" },
        "reduces_risk_if_delayed": { "type": "boolean" },
        "is_lower_value_optimization": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "recent_updates": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
