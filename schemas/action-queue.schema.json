{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://health-agent.local/schemas/action-queue.schema.json",
  "title": "ActionQueue",
  "type": "object",
  "required": ["profile_slug", "profile_name", "generated_at", "actions"],
  "properties": {
    "profile_slug": { "type": "string", "minLength": 1 },
    "profile_name": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "minLength": 1 },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rank",
          "issue_slug",
          "issue_title",
          "priority_bucket",
          "priority_label",
          "do_next",
          "why",
          "specialist_type",
          "what_to_ask_for",
          "what_result_to_return_with",
          "expected_payoff",
          "owner",
          "related_issues"
        ],
        "properties": {
          "rank": { "type": "integer", "minimum": 1 },
          "issue_slug": { "type": "string", "minLength": 1 },
          "issue_title": { "type": "string", "minLength": 1 },
          "priority_bucket": {
            "enum": [
              "materially_narrows_differential",
              "changes_treatment_or_specialist_path",
              "resolves_missing_objective_evidence",
              "reduces_risk_if_delayed",
              "lower_value_optimization"
            ]
          },
          "priority_label": { "type": "string", "minLength": 1 },
          "do_next": { "type": "string", "minLength": 1 },
          "why": { "type": "string", "minLength": 1 },
          "specialist_type": { "type": "string", "minLength": 1 },
          "what_to_ask_for": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "what_result_to_return_with": { "type": "string", "minLength": 1 },
          "expected_payoff": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "related_issues": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
